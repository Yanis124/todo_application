144:                 <span className={`badge ${task.priority}`}>{task.priority}</span>
145:                 <span className={`badge ${task.status}`}>{task.status.replace('_', ' ')}</span>
146:                 <div className="task-actions">
147:                   <button onClick={() => handleEdit(task)}>Edit</button>
148:                   <button className="delete" onClick={() => handleDeleteTask(task.id)}>Delete</button>
149:                 </div>
150:               </div>
151:             </div>
152:           ))}
153:         </div>
154:       </div>
155: 
156:       {showModal && (
157:         <TaskModal
158:           task={editingTask}
159:           onSave={handleSaveTask}
160:           onClose={() => { setShowModal(false); setEditingTask(null) }}
161:         />
162:       )}
163:     </div>
164:   )
165: }
