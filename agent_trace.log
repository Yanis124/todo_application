database.py, app/models/{user,task}.py, app/schemas/{user,task,token}.py, app/routers/{auth,tasks,health}.py, app/services/{auth_service,task_service}.py, app/core/{security,dependencies}.py\n\n2. FRONTEND FILE STRUCTURE: src/main.jsx, src/App.jsx, src/api/{client,auth,tasks}.js, src/context/AuthContext.jsx, src/hooks/useTasks.js, src/pages/{LoginPage,RegisterPage,DashboardPage}.jsx, src/components/{TaskList,TaskCard,TaskForm,TaskFilter,ProtectedRoute,Navbar}.jsx\n\n3. API CONTRACTS:\n- POST /api/auth/register (UserCreate -> UserResponse, 201)\n- POST /api/auth/login (UserLogin -> Token, 200)\n- GET /api/auth/me (-> UserResponse, 200, auth required)\n- GET /api/tasks/ (TaskFilter query params -> List[TaskResponse], 200, auth required)\n- POST /api/tasks/ (TaskCreate -> TaskResponse, 201, auth required)\n- GET /api/tasks/{id} (-> TaskResponse, 200, auth required)\n- PUT /api/tasks/{id} (TaskUpdate -> TaskResponse, 200, auth required)\n- DELETE /api/tasks/{id} (-> 204, auth required)\n- GET /api/health (-> {status: healthy}, 200)\n\n4. AUTH CONTRACT: JWT Bearer token in Authorization header, stored in localStorage as 'access_token'\n\n5. ENUMS: PriorityEnum(low/medium/high/urgent), StatusEnum(todo/in_progress/done/cancelled)\n\n6. DEPENDENCIES: fastapi, uvicorn, sqlalchemy, pydantic, pydantic-settings, python-jose, passlib[bcrypt], python-multipart, pytest, httpx\n\n7. SERVICES: AuthService (register_user, authenticate_user, get_user_by_email), TaskService (create_task, get_tasks, get_task, update_task, delete_task)\n\n8. SECURITY: create_access_token, decode_token, hash_password, verify_password, get_current_user (FastAPI Depends)"}
