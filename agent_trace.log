1: from datetime import datetime
2: 
3: from fastapi import APIRouter, Depends
4: from sqlalchemy.orm import Session
5: 
6: from app.database import get_db
7: from app.models import Task, User, TaskStatus, TaskPriority
8: from app.schemas import DashboardStats
9: from app.auth import get_current_user
10: 
11: router = APIRouter(prefix="/api/dashboard", tags=["Dashboard"])
12: 
13: 
14: @router.get("/stats", response_model=DashboardStats)
15: def get_dashboard_stats(
16:     current_user: User = Depends(get_current_user),
17:     db: Session = Depends(get_db),
18: ):
19:     base_query = db.query(Task).filter(Task.owner_id == current_user.id)
20: 
21:     total_tasks = base_query.count()
22:     todo_count = base_query.filter(Task.status == TaskStatus.TODO).count()
23:     in_progress_count = base_query.filter(Task.status == TaskStatus.IN_PROGRESS).count()
24:     done_count = base_query.filter(Task.status == TaskStatus.DONE).count()
25:     overdue_count = base_query.filter(
26:         Task.due_date < datetime.utcnow(),
27:         Task.status != TaskStatus.DONE
28:     ).count()
29:     high_priority_count = base_query.filter(Task.priority == TaskPriority.HIGH).count()
30: 
31:     return DashboardStats(
32:         total_tasks=total_tasks,
33:         todo_count=todo_count,
34:         in_progress_count=in_progress_count,
35:         done_count=done_count,
36:         overdue_count=overdue_count,
37:         high_priority_count=high_priority_count,
38:     )
