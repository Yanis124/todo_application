elds": {\n          "id": {"type": "Integer", "primary_key": true, "index": true},\n          "username": {"type": "String", "unique": true, "nullable": false, "index": true},\n          "email": {"type": "String", "unique": true, "nullable": false, "index": true},\n          "hashed_password": {"type": "String", "nullable": false},\n          "created_at": {"type": "DateTime", "default": "utcnow"}\n        },\n        "relationships": {\n          "tasks": {"target": "Task", "back_populates": "owner"}\n        }\n      },\n      "Task": {\n        "table_name": "tasks",\n        "fields": {\n          "id": {"type": "Integer", "primary_key": true, "index": true},\n          "title": {"type": "String", "nullable": false},\n          "description": {"type": "String", "default": ""},\n          "priority": {"type": "Enum(TaskPriority)", "default": "medium"},\n          "status": {"type": "Enum(TaskStatus)", "default": "todo"},\n          "due_date": {"type": "DateTime", "nullable": true},\n          "owner_id": {"type": "Integer", "foreign_key": "users.id", "nullable": false},\n          "created_at": {"type": "DateTime", "default": "utcnow"},\n          "updated_at": {"type": "DateTime", "default": "utcnow", "onupdate": "utcnow"}\n        },\n        "relationships": {\n          "owner": {"target": "User", "back_populates": "tasks"}\n        }\n      }\n    },\n\n    "enums": {\n      "TaskPriority": ["low", "medium", "high"],\n      "TaskStatus": ["todo", "in_progress", "done"]\n    },\n\n    "schemas": {\n      "UserCreate": {\n        "fields": {\n          "username": {"type": "str", "required": true, "min_length": 3, "max_length": 50},\n          "email": {"type": "str", "required": true, "min_length": 5, "max_length": 100},\n          "password": {"type": "str", "required": true, "min_length": 6}\n        }\n      },\n      "LoginRequest": {\n        "fields": {\n          "username": {"type": "str", "required": true},\n          "password": {"type": "str", "required": true}\n        },\n        "NOTE": "Feature list F-002 specifies login by EMAIL. Current implementation uses USERNAME. See feedback to developer."\n      },\n      "UserResponse": {\n        "fields": {\n          "id": {"type": "int"},\n          "username": {"type": "str"},\n          "email": {"type": "str"},\n          "created_at": {"type": "datetime"}\n        },\n        "config": {"from_attributes": true}\n      },\n      "TaskCreate": {\n        "fields": {\n          "title": {"type": "str", "required": true, "min_length": 1, "max_length": 200},\n          "description": {"type": "Optional[str]", "default": ""},\n          "priority": {"type": "TaskPriority", "default": "medium"},\n          "status": {"type": "TaskStatus", "default": "todo"},\n          "due_date": {"type": "Optional[datetime]", "default": null}\n        }\n      },\n      "TaskUpdate": {\n        "fields": {\n          "title": {"type": "Optional[str]", "min_length": 1, "max_length": 200},\n          "description": {"type": "Optional[str]"},\n          "priority": {"type": "Optional[TaskPriority]"},\n          "status": {"type": "Optional[TaskStatus]"},\n          "due_date": {"type": "Optional[datetime]"}\n        }\n      },\n      "TaskResponse": {\n        "fields": {\n          "id": {"type": "int"},\n          "title": {"type": "str"},\n          "description": {"type": "str"},\n          "priority": {"type": "TaskPriority"},\n          "status": {"type": "TaskStatus"},\n          "due_date": {"type": "Optional[datetime]"},\n          "created_at": {"type": "datetime"},\n          "updated_at": {"type": "datetime"},\n          "owner_id": {"type": "int"}\n        },\n        "config": {"from_attributes": true}\n      },\n      "DashboardStats": {\n        "fields": {\n          "total_tasks": {"type": "int"},\n          "todo_count": {"type": "int"},\n          "in_progress_count": {"type": "int"},\n          "done_count": {"type": "int"},\n          "overdue_count": {"type": "int"},\n          "high_priority_count": {"type": "int"}\n        }\n      },\n      "Token": {\n        "fields": {\n          "access_token": {"type": "str"},\n          "token_type": {"type": "str", "default": "bearer"}\n        }\n      },\n      "TokenData": {\n        "fields": {\n          "user_id": {"type": "Optional[int]"}\n        }\n      }\n    },\n\n    "api_endpoints": {\n      "root": {\n        "prefix": "/",\n        "tag": "Root",\n        "endpoints": [\n          {"method": "GET", "path": "/", "response": "{message, docs}", "status_code": 200, "auth_required": false}\n        ]\n      },\n      "health": {\n        "prefix": "/",\n        "tag": "Health",\n        "endpoints": [\n          {"method": "GET", "path": "/health", "response": "{status: healthy}", "status_code": 200, "auth_required": false}\n        ]\n      },\n      "auth": {\n        "prefix": "/api/auth",\n        "tag": "Authentication",\n        "endpoints": [\n          {\n            "method": "POST",\n            "path": "/register",\n            "request_body": "UserCreate",\n            "response": "UserResponse",\n            "status_code": 201,\n            "auth_required": false,\n            "error_codes": [400, 409],\n            "description": "Register a new user. Should return 409 for duplicate email per feature_list F-001."\n          },\n          {\n            "method": "POST",\n            "path": "/login",\n            "request_body": "LoginRequest",\n            "response": "Token",\n            "status_code": 200,\n            "auth_required": false,\n            "error_codes": [401],\n            "description": "Login and receive JWT token. Feature list F-002 specifies email-based login."\n          },\n          {\n            "method": "GET",\n            "path": "/me",\n            "response": "UserResponse",\n            "status_code": 200,\n            "auth_required": true,\n            "description": "Get current authenticated user profile"\n          }\n        ]\n      },\n      "tasks": {\n        "prefix": "/api/tasks",\n        "tag": "Tasks",\n        "endpoints": [\n          {\n            "method": "GET",\n            "path": "/",\n            "query_params": {\n              "status": "Optional[TaskStatus]",\n              "priority": "Optional[TaskPriority]",\n              "due_before": "Optional[datetime]",\n              "due_after": "Optional[datetime]",\n              "search": "Optional[str]",\n              "skip": "int (default=0)",\n              "limit": "int (default=100, max=1000)"\n            },\n            "response": "List[TaskResponse]",\n            "status_code": 200,\n            "auth_required": true,\n            "description": "List tasks for current user with optional filters"\n          },\n          {\n            "method": "POST",\n            "path": "/",\n            "request_body": "TaskCreate",\n            "response": "TaskResponse",\n            "status_code": 201,\n            "auth_required": true\n          },\n          {\n            "method": "GET",\n            "path": "/{task_id}",\n            "response": "TaskResponse",\n            "status_code": 200,\n            "auth_required": true,\n            "error_codes": [404]\n          },\n          {\n            "method": "PUT",\n            "path": "/{task_id}",\n            "request_body": "TaskUpdate",\n            "response": "TaskResponse",\n            "status_code": 200,\n            "auth_required": true,\n            "error_codes": [404]\n          },\n          {\n            "method": "DELETE",\n            "path": "/{task_id}",\n            "response": null,\n            "status_code": 204,\n            "auth_required": true,\n            "error_codes": [404]\n          }\n        ]\n      },\n      "dashboard": {\n        "prefix": "/api/dashboard",\n        "tag": "Dashboard",\n        "endpoints": [\n          {\n            "method": "GET",\n            "path": "/stats",\n            "response": "DashboardStats",\n            "status_code": 200,\n            "auth_required": true,\n            "description": "Get dashboard statistics for current user"\n          }\n        ]\n      }\n    },\n\n    "security": {\n      "jwt": {\n        "file": "app/auth.py",\n        "algorithm": "HS256",\n        "token_expire_minutes": 30,\n        "functions": [\n          {"name": "create_access_token", "params": "data: dict, expires_delta: Optional[timedelta] = None", "returns": "str"},\n          {"name": "get_current_user", "params": "token: str = Depends(oauth2_scheme), db: Session = Depends(get_db)", "returns": "User"}\n        ]\n      },\n      "password": {\n        "file": "app/auth.py",\n        "scheme": "bcrypt (direct, not passlib)",\n        "functions": [\n          {"name": "get_password_hash", "params": "password: str", "returns": "str"},\n          {"name": "verify_password", "params": "plain_password: str, hashed_password: str", "returns": "bool"}\n        ]\n      }\n    },\n\n    "config": {\n      "file": "app/config.py",\n      "class_name": "Settings",\n      "fields": {\n        "SECRET_KEY": {"type": "str", "default": "your-secret-key-change-in-production"},\n        "ALGORITHM": {"type": "str", "default": "HS256"},\n        "ACCESS_TOKEN_EXPIRE_MINUTES": {"type": "int", "default": 30},\n        "DATABASE_URL": {"type": "str", "default": "sqlite:///./todo.db"}\n      }\n    },\n\n    "database": {\n      "file": "app/database.py",\n      "exports": ["engine", "SessionLocal", "Base", "get_db"]\n    }\n  },\n\n  "frontend": {\n    "framework": "React 18",\n    "build_tool": "Vite",\n    "language": "JavaScript (JSX)",\n    "entry_point": "src/main.jsx",\n\n    "file_structure": {\n      "src/main.jsx": "React root render with BrowserRouter and AuthProvider",\n      "src/App.jsx": "Route definitions, layout, protected routes",\n      "src/api/client.js": "Axios instance with baseURL and JWT interceptor",\n      "src/api/auth.js": "API functions: login(), register(), getMe()",\n      "src/api/tasks.js": "API functions: getTasks(), createTask(), updateTask(), deleteTask()",\n      "src/context/AuthContext.jsx": "AuthContext provider: user, token, login, logout, register",\n      "src/hooks/useTasks.js": "Custom hook for task CRUD and filtering",\n      "src/pages/LoginPage.jsx": "Login form page",\n      "src/pages/RegisterPage.jsx": "Registration form page",\n      "src/pages/DashboardPage.jsx": "Main dashboard with task list, filters, and stats",\n      "src/components/TaskList.jsx": "Renders list of TaskCard components",\n      "src/components/TaskCard.jsx": "Single task display with edit/delete actions",\n      "src/components/TaskForm.jsx": "Form for creating/editing tasks",\n      "src/components/TaskFilter.jsx": "Filter controls: priority, status, date range, search",\n      "src/components/ProtectedRoute.jsx": "Route wrapper that redirects to login if not authenticated",\n      "src/components/Navbar.jsx": "Navigation bar with user info and logout"\n    },\n\n    "dependencies": [\n      "react@^18.2.0",\n      "react-dom@^18.2.0",\n      "react-router-dom@^6.20.0",\n      "axios@^1.6.0"\n    ],\n\n    "api_base_url": "http://localhost:8000",\n\n    "routes": [\n      {"path": "/login", "component": "LoginPage", "protected": false},\n      {"path": "/register", "component": "RegisterPage", "protected": false},\n      {"path": "/", "component": "DashboardPage", "protected": true},\n      {"path": "/dashboard", "component": "DashboardPage", "protected": true}\n    ]\n  },\n\n  "cross_module_contracts": {\n    "authentication_flow": {\n      "description": "Frontend sends credentials to /api/auth/login, receives JWT token, stores in localStorage, sends as Authorization: Bearer <token> header",\n      "token_header": "Authorization",\n      "token_prefix": "Bearer",\n      "token_storage": "localStorage",\n      "token_key": "access_token"\n    },\n    "error_format": {\n      "format": {"detail"