[2026-03-26T20:40:16.033283] [TOOL_CALL] [write_file] args=() kwargs={'filepath': 'output/src/frontend/src/components/TaskModal.jsx', 'content': 'import React, { useState } from \'react\'\n\nfunction TaskModal({ task, onSave, onClose }) {\n  const [title, setTitle] = useState(task?.title || \'\')\n  const [description, setDescription] = useState(task?.description || \'\')\n  const [priority, setPriority] = useState(task?.priority || \'medium\')\n  const [status, setStatus] = useState(task?.status || \'todo\')\n  const [dueDate, setDueDate] = useState(\n    task?.due_date ? task.due_date.slice(0, 16) : \'\'\n  )\n\n  const handleSubmit = (e) => {\n    e.preventDefault()\n    const data = { title, description, priority, status }\n    if (dueDate) data.due_date = new Date(dueDate).toISOString()\n    onSave(data)\n  }\n\n  return (\n    <div className="modal-overlay" onClick={onClose}>\n      <div className="modal" onClick={(e) => e.stopPropagation()}>\n        <h2>{task ? \'Edit Task\' : \'New Task\'}</h2>\n        <form onSubmit={handleSubmit}>\n          <label>Title</label>\n          <input\n            type="text" value={title}\n            onChange={(e) => setTitle(e.target.value)} required\n          />\n          <label>Description</label>\n          <textarea\n            value={description}\n            onChange={(e) => setDescription(e.target.value)}\n          />\n          <label>Priority</label>\n          <select value={priority} onChange={(e) => setPriority(e.target.value)}>\n            <option value="low">Low</option>\n            <option value="medium">Medium</option>\n            <option value="high">High</option>\n          </select>\n          <label>Status</label>\n          <select value={status} onChange={(e) => setStatus(e.target.value)}>\n            <option value="todo">To Do</option>\n            <option value="in_progress">In Progress</option>\n            <option value="done">Done</option>\n          </select>\n          <label>Due Date</label>\n          <input\n            type="datetime-local" value={dueDate}\n            onChange={(e) => setDueDate(e.target.value)}\n          />\n          <div className="modal-actions">\n            <button type="button" className="cancel" onClick={onClose}>Cancel</button>\n            <button type="submit" className="save">Save</button>\n          </div>\n        </form>\n      </div>\n    </div>\n  )\n}\n\nexport default TaskModal\n'}
