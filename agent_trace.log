16:     onSave(data)
17:   }
18: 
19:   return (
20:     <div className="modal-overlay" onClick={onClose}>
21:       <div className="modal" onClick={(e) => e.stopPropagation()}>
22:         <h2>{task ? 'Edit Task' : 'New Task'}</h2>
23:         <form onSubmit={handleSubmit}>
24:           <label>Title</label>
25:           <input
26:             type="text" value={title}
27:             onChange={(e) => setTitle(e.target.value)} required
28:           />
29:           <label>Description</label>
30:           <textarea
31:             value={description}
32:             onChange={(e) => setDescription(e.target.value)}
33:           />
34:           <label>Priority</label>
35:           <select value={priority} onChange={(e) => setPriority(e.target.value)}>
36:             <option value="low">Low</option>
37:             <option value="medium">Medium</option>
38:             <option value="high">High</option>
39:           </select>
40:           <label>Status</label>
