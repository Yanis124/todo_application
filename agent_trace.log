9: 
10: app = FastAPI(
11:     title="Todo App API",
12:     description="A To-Do application with JWT authentication, CRUD tasks, and filterable dashboard",
13:     version="1.0.0",
14:     docs_url="/docs",
15:     redoc_url="/redoc",
16: )
17: 
18: # CORS middleware
19: app.add_middleware(
20:     CORSMiddleware,
21:     allow_origins=["http://localhost:3000", "http://localhost:5173"],
22:     allow_credentials=True,
23:     allow_methods=["*"],
24:     allow_headers=["*"],
25: )
26: 
27: # Include routers
28: app.include_router(auth_router.router)
29: app.include_router(task_router.router)
30: app.include_router(dashboard_router.router)
31: 
32: 
33: @app.get("/", tags=["Root"])
34: def root():
35:     return {"message": "Todo App API", "docs": "/docs"}
