1: from datetime import datetime, timedelta
2: from typing import Optional
3: 
4: from jose import JWTError, jwt
5: import bcrypt
6: from fastapi import Depends, HTTPException, status
7: from fastapi.security import OAuth2PasswordBearer
8: from sqlalchemy.orm import Session
9: 
10: from app.config import settings
11: from app.database import get_db
12: from app.models import User
13: from app.schemas import TokenData
14: 
15: oauth2_scheme = OAuth2PasswordBearer(tokenUrl="/api/auth/login")
16: 
17: 
18: def verify_password(plain_password: str, hashed_password: str) -> bool:
19:     return bcrypt.checkpw(
20:         plain_password.encode("utf-8"),
21:         hashed_password.encode("utf-8")
22:     )
23: 
24: 
25: def get_password_hash(password: str) -> str:
26:     salt = bcrypt.gensalt()
27:     hashed = bcrypt.hashpw(password.encode("utf-8"), salt)
28:     return hashed.decode("utf-8")
29: 
30: 
31: def create_access_token(data: dict, expires_delta: Optional[timedelta] = None) -> str:
32:     to_encode = data.copy()
33:     # Ensure sub is a string (JWT spec requires it)
34:     if "sub" in to_encode:
35:         to_encode["sub"] = str(to_encode["sub"])
36:     if expires_delta:
37:         expire = datetime.utcnow() + expires_delta
38:     else:
39:         expire = datetime.utcnow() + timedelta(minutes=settings.ACCESS_TOKEN_EXPIRE_MINUTES)
40:     to_encode.update({"exp": expire})
41:     encoded_jwt = jwt.encode(to_encode, settings.SECRET_KEY, algorithm=settings.ALGORITHM)
42:     return encoded_jwt
43: 
44: 
45: def get_current_user(token: str = Depends(oauth2_scheme), db: Session = Depends(get_db)) -> User:
46:     credentials_exception = HTTPException(
47:         status_code=status.HTTP_401_UNAUTHORIZED,
48:         detail="Could not validate credentials",
49:         headers={"WWW-Authenticate": "Bearer"},
50:     )
51:     try:
52:         payload = jwt.decode(token, settings.SECRET_KEY, algorithms=[settings.ALGORITHM])
53:         sub: str = payload.get("sub")
54:         if sub is None:
55:             raise credentials_exception
56:         user_id = int(sub)
57:         token_data = TokenData(user_id=user_id)
58:     except (JWTError, ValueError):
59:         raise credentials_exception
60: 
61:     user = db.query(User).filter(User.id == token_data.user_id).first()
62:     if user is None:
63:         raise credentials_exception
64:     return user
