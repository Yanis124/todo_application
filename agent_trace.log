26:       {error && <div className="error-msg">{error}</div>}
27:       <form onSubmit={handleSubmit}>
28:         <input
29:           type="email" placeholder="Email" value={email}
30:           onChange={(e) => setEmail(e.target.value)} required
31:         />
32:         <input
33:           type="password" placeholder="Password" value={password}
34:           onChange={(e) => setPassword(e.target.value)} required
35:         />
36:         <button type="submit">Login</button>
37:       </form>
38:       <div className="toggle">
39:         Don't have an account? <Link to="/register">Register</Link>
40:       </div>
41:     </div>
42:   )
43: }
