42:             <option value="todo">To Do</option>
43:             <option value="in_progress">In Progress</option>
44:             <option value="done">Done</option>
45:           </select>
46:           <label>Due Date</label>
47:           <input
48:             type="datetime-local" value={dueDate}
49:             onChange={(e) => setDueDate(e.target.value)}
50:           />
51:           <div className="modal-actions">
52:             <button type="button" className="cancel" onClick={onClose}>Cancel</button>
53:             <button type="submit" className="save">Save</button>
54:           </div>
55:         </form>
56:       </div>
57:     </div>
58:   )
