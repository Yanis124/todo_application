1: import React, { useState } from 'react'
2: import { Link, useNavigate } from 'react-router-dom'
3: import { authAPI } from '../api'
4: 
5: function Register({ onLogin }) {
6:   const [username, setUsername] = useState('')
7:   const [email, setEmail] = useState('')
8:   const [password, setPassword] = useState('')
9:   const [error, setError] = useState('')
10:   const navigate = useNavigate()
11: 
12:   const handleSubmit = async (e) => {
13:     e.preventDefault()
14:     setError('')
15:     try {
16:       await authAPI.register({ username, email, password })
17:       // Auto-login after registration
18:       const res = await authAPI.login({ username, password })
19:       onLogin(res.data.access_token)
20:       navigate('/')
21:     } catch (err) {
22:       setError(err.response?.data?.detail || 'Registration failed')
23:     }
24:   }
25: 
26:   return (
27:     <div className="auth-form">
28:       <h2>Register</h2>
29:       {error && <div className="error-msg">{error}</div>}
30:       <form onSubmit={handleSubmit}>
31:         <input
32:           type="text" placeholder="Username" value={username}
33:           onChange={(e) => setUsername(e.target.value)} required
34:         />
35:         <input
36:           type="email" placeholder="Email" value={email}
37:           onChange={(e) => setEmail(e.target.value)} required
38:         />
39:         <input
40:           type="password" placeholder="Password (min 6 chars)" value={password}
41:           onChange={(e) => setPassword(e.target.value)} required
42:         />
43:         <button type="submit">Register</button>
44:       </form>
45:       <div className="toggle">
46:         Already have an account? <Link to="/login">Login</Link>
47:       </div>
48:     </div>
49:   )
50: }
51: 
52: export default Register
