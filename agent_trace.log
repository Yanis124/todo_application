118:             <option value="in_progress">In Progress</option>
119:             <option value="done">Done</option>
120:           </select>
121:           <select value={filters.priority} onChange={(e) => setFilters({...filters, priority: e.target.value})}>
122:             <option value="">All Priorities</option>
123:             <option value="high">High</option>
124:             <option value="medium">Medium</option>
125:             <option value="low">Low</option>
126:           </select>
127:           <input
128:             type="text" placeholder="Search tasks..."
129:             value={filters.search}
130:             onChange={(e) => setFilters({...filters, search: e.target.value})}
131:           />
132:         </div>
133: 
134:         <div className="task-list">
135:           {tasks.length === 0 && <p>No tasks found.</p>}
136:           {tasks.map((task) => (
137:             <div key={task.id} className="task-card">
138:               <div className="task-info">
139:                 <h3>{task.title}</h3>
140:                 <p>{task.description}</p>
141:                 {task.due_date && <p>Due: {formatDate(task.due_date)}</p>}
142:               </div>
