12: router = APIRouter(prefix="/api/auth", tags=["Authentication"])
13: 
14: 
15: @router.post("/register", response_model=UserResponse, status_code=status.HTTP_201_CREATED)
16: def register(user_data: UserCreate, db: Session = Depends(get_db)):
17:     # Check if username exists
18:     existing_user = db.query(User).filter(User.username == user_data.username).first()
19:     if existing_user:
20:         raise HTTPException(
21:             status_code=status.HTTP_400_BAD_REQUEST,
22:             detail="Username already registered"
23:         )
24:     # Check if email exists
25:     existing_email = db.query(User).filter(User.email == user_data.email).first()
26:     if existing_email:
27:         raise HTTPException(
28:             status_code=status.HTTP_400_BAD_REQUEST,
29:             detail="Email already registered"
30:         )
31:     # Create user
32:     hashed_password = get_password_hash(user_data.password)
33:     db_user = User(
34:         username=user_data.username,
35:         email=user_data.email,
36:         hashed_password=hashed_password
37:     )
38:     db.add(db_user)
39:     db.commit()
40:     db.refresh(db_user)
41:     return db_user
42: 
43: 
44: @router.post("/login", response_model=Token)
45: def login(login_data: LoginRequest, db: Session = Depends(get_db)):
46:     user = db.query(User).filter(User.username == login_data.username).first()
47:     if not user or not verify_password(login_data.password, user.hashed_password):
48:         raise HTTPException(
49:             status_code=status.HTTP_401_UNAUTHORIZED,
50:             detail="Incorrect username or password",
51:             headers={"WWW-Authenticate": "Bearer"},
52:         )
53:     access_token_expires = timedelta(minutes=settings.ACCESS_TOKEN_EXPIRE_MINUTES)
54:     access_token = create_access_token(
55:         data={"sub": user.id}, expires_delta=access_token_expires
56:     )
57:     return {"access_token": access_token, "token_type": "bearer"}
58: 
59: 
60: @router.get("/me", response_model=UserResponse)
61: def get_me(current_user: User = Depends(get_current_user)):
62:     return current_user
